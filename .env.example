# ======================================================
# PowerPrice Futures Signals – Environment Configuration
# SIGNAL ONLY – No live trading execution
# ======================================================

# Application
APP_NAME=PowerPrice Futures Signals
APP_ENV=development
SIGNAL_ONLY=true
SECRET_KEY=change-me-in-production
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://ppuser:pppass@postgres:5432/powerprice
DATABASE_URL_SYNC=postgresql+psycopg2://ppuser:pppass@postgres:5432/powerprice

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Data Sources
ENTSOE_API_KEY=
SMARD_BASE_URL=https://www.smard.de/app/chart_data
ENTSOE_BASE_URL=https://transparency.entsoe.eu/api
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# ML Models
MODEL_DIR=/app/models
RETRAIN_INTERVAL_HOURS=24

# ======================================================
# Signal Daemon
# ======================================================
SIGNAL_DAEMON_ENABLED=true
SIGNAL_LOOP_INTERVAL_MINUTES=15
DATA_STALE_MAX_MINUTES=90
MAX_CONSECUTIVE_ERRORS=5

# ======================================================
# Telegram Notifications
# ======================================================
TELEGRAM_ENABLED=false
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Start a chat with your bot, then get chat ID via:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_SIGNAL_LEVEL=WATCH
TELEGRAM_SEND_BLOCKED_SIGNALS=false
TELEGRAM_SEND_DAILY_SUMMARY=true
SIGNAL_DEDUP_MINUTES=60

# ======================================================
# Adaptive Retraining
# ======================================================
AUTO_RETRAIN_ENABLED=true
ROLLING_TRAINING_DAYS=365
DRIFT_CHECK_ENABLED=true
DRIFT_CHECK_INTERVAL_HOURS=6
TIME_DECAY_ENABLED=false
TIME_DECAY_HALF_LIFE_DAYS=180

# ======================================================
# Signal Mode
# ======================================================
SIGNAL_MODE=NORMAL

# ======================================================
# Futures Parameters
# ======================================================
FUTURES_AVG_SPREAD_EUR_MWH=5.0
FUTURES_SLIPPAGE_EUR_MWH=3.0
FUTURES_OVERNIGHT_FEE_ANNUAL_PCT=8.0
FUTURES_MIN_EDGE_THRESHOLD=30.0
FUTURES_HIGH_CONFIDENCE_THRESHOLD=35.0
FUTURES_P_REBOUND_ENTRY=0.70
FUTURES_P_REBOUND_WATCH=0.55

# ======================================================
# Risk Limits
# ======================================================
MAX_TAIL_RISK_SCORE=0.65
MAX_NEGATIVE_PRICE_EUR_MWH=-150.0
MAX_NEGATIVE_STREAK_HOURS=3
MAX_GAP_SIZE_EUR_MWH=100.0
