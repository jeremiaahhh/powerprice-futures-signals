# Application
APP_NAME=PowerPrice Futures Signals
APP_ENV=development
SIGNAL_ONLY=true
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://ppuser:pppass@postgres:5432/powerprice
DATABASE_URL_SYNC=postgresql+psycopg2://ppuser:pppass@postgres:5432/powerprice

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Data Sources
ENTSOE_API_KEY=your-entsoe-api-key-here
SMARD_BASE_URL=https://www.smard.de/app/chart_data
ENTSOE_BASE_URL=https://transparency.entsoe.eu/api
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# ML Models
MODEL_DIR=/app/models
RETRAIN_INTERVAL_HOURS=24

# Futures Cost Model Defaults
FUTURES_AVG_SPREAD_EUR_MWH=5.0
FUTURES_SLIPPAGE_EUR_MWH=3.0
FUTURES_OVERNIGHT_FEE_ANNUAL_PCT=8.0
FUTURES_SAFETY_BUFFER_EUR_MWH=5.0
FUTURES_MIN_EDGE_THRESHOLD=10.0

# Telegram Notifications (Signal only — no order execution)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
TELEGRAM_MIN_SIGNAL_LEVEL=WATCH
TELEGRAM_SEND_BLOCKED_SIGNALS=false
TELEGRAM_SEND_DAILY_SUMMARY=true
SIGNAL_DEDUP_MINUTES=60
